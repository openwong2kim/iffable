{
  "_comment": "iffable — example hook wiring. MERGE these keys into your existing Claude Code settings; do NOT overwrite the file. Keep hooks/env in settings.local.json to dodge the Claude Code /model auto-migration bug (#22659) that strips hooks.",

  "_env_comment": "IFFABLE_PROFILE=auto -> profile is decided by the session's startup model (model contains 'fable' -> armed; else dormant). Force fable/fallback/off to override. IFFABLE_SPAWN_LIMIT is the char length above which the spawn ledger guard applies.",
  "env": {
    "IFFABLE_HOME": "$HOME/.claude/iffable",
    "IFFABLE_PROFILE": "auto",
    "IFFABLE_SPAWN_LIMIT": "1500"
  },

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "IFFABLE_HOME=\"$HOME/.claude/iffable\" python3 \"$HOME/.claude/iffable/iffable.py\" session-start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent|Task|Workflow",
        "hooks": [
          {
            "type": "command",
            "command": "IFFABLE_HOME=\"$HOME/.claude/iffable\" python3 \"$HOME/.claude/iffable/iffable.py\" guard-spawn"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "IFFABLE_HOME=\"$HOME/.claude/iffable\" python3 \"$HOME/.claude/iffable/iffable.py\" guard-stop"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "IFFABLE_HOME=\"$HOME/.claude/iffable\" python3 \"$HOME/.claude/iffable/iffable.py\" session-end"
          }
        ]
      }
    ]
  }
}
